{
  "name": "@luminarylabs/nexusrealtime-experiments",
  "version": "0.0.2",
  "type": "module",
  "private": true,
  "description": "NexusRealtime browser experiments composed from kits.",
  "devDependencies": {
    "@luminarylabs/nexusrealtime-protokits": "github:LuminaryLabs-Agents/NexusRealtime-ProtoKits#main",
    "nexusrealtime": "github:LuminaryLabs-Dev/NexusRealtime#main",
    "playwright": "^1.56.0"
  },
  "scripts": {
    "generate:application-routes": "node scripts/generate-application-routes.mjs",
    "generate:flat-routes": "npm run generate:application-routes",
    "generate:gallery-data": "node scripts/generate-gallery-data.mjs",
    "generate": "npm run generate:application-routes && npm run generate:gallery-data",
    "capture:covers": "node tools/capture-route-covers.mjs",
    "check:covers": "node tools/capture-route-covers.mjs --dry-run",
    "check": "npm run generate && node scripts/run-checks.mjs",
    "check:deploy": "npm run generate && node scripts/run-checks.mjs --deploy"
  },
  "license": "MIT"
}
